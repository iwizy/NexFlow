{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexflow.dev/schemas/common.schema.json",
  "title": "NexFlow Common Definitions",
  "type": "object",
  "$defs": {
    "specVersion": {
      "title": "Spec Version",
      "description": "NexFlow spec version used to interpret the manifest.",
      "type": "string",
      "enum": ["0.1"]
    },
    "id": {
      "title": "Identifier",
      "description": "Stable, case-sensitive identifier. It starts with a lowercase letter and uses lowercase letters, digits, and non-empty segments separated by hyphens or underscores.",
      "type": "string",
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:[-_][a-z0-9]+)*$",
      "examples": ["docs-agent", "read_repository"]
    },
    "eventType": {
      "title": "Event Type",
      "description": "Dotted lowercase event type. Event types are a separate namespace from entity identifiers.",
      "type": "string",
      "pattern": "^[a-z]+(?:\\.[a-z]+)+$",
      "examples": ["task.completed", "review.requested"]
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "project": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        }
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "idList": {
      "title": "Identifier List",
      "description": "Unique identifiers or identifier references. The containing field determines the target namespace for references.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "referenceTargetKind": {
      "title": "Reference Target Kind",
      "description": "Closed target-kind vocabulary for typed resource references in the 0.1 draft.",
      "type": "string",
      "enum": [
        "project",
        "project-maintainer",
        "actor",
        "agent",
        "agent-definition",
        "capability",
        "permission",
        "approval-gate",
        "context-source",
        "memory-scope",
        "provider",
        "model-profile",
        "prompt-set",
        "prompt",
        "retrieval-profile",
        "task",
        "workflow",
        "workflow-stage",
        "workflow-step",
        "handoff",
        "artifact",
        "extension"
      ]
    },
    "typedReferenceScope": {
      "title": "Typed Reference Scope",
      "description": "Explicit owner namespace for a scoped typed reference.",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/referenceTargetKind"
        },
        "id": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "typedReference": {
      "title": "Typed Reference",
      "description": "Deterministic kind, ID, and optional scope tuple. Resolution never grants authority.",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/referenceTargetKind"
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "scope": {
          "$ref": "#/$defs/typedReferenceScope"
        }
      }
    },
    "resourceReference": {
      "title": "Transitional Resource Reference",
      "description": "Scalar ID or typed reference object for field contracts that explicitly permit both authored forms during migration.",
      "oneOf": [
        {
          "$ref": "#/$defs/id"
        },
        {
          "$ref": "#/$defs/typedReference"
        }
      ]
    },
    "resourceReferenceList": {
      "title": "Transitional Resource Reference List",
      "description": "Unique scalar or typed resource references where an owning field contract permits both forms.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/resourceReference"
      },
      "uniqueItems": true
    },
    "actorReference": {
      "title": "Actor Reference",
      "description": "Assembly-scoped typed reference to an ActorSet declaration.",
      "allOf": [
        {
          "$ref": "#/$defs/typedReference"
        },
        {
          "properties": {
            "kind": {
              "const": "actor"
            }
          },
          "not": {
            "required": ["scope"]
          }
        }
      ]
    },
    "agentReference": {
      "title": "Agent Reference",
      "description": "Assembly-scoped typed reference to an AgentSet declaration.",
      "allOf": [
        {
          "$ref": "#/$defs/typedReference"
        },
        {
          "properties": {
            "kind": {
              "const": "agent"
            }
          },
          "not": {
            "required": ["scope"]
          }
        }
      ]
    },
    "extensionReference": {
      "title": "Extension Reference",
      "description": "Assembly-scoped typed reference to an ExtensionSet declaration.",
      "allOf": [
        {
          "$ref": "#/$defs/typedReference"
        },
        {
          "properties": {
            "kind": {
              "const": "extension"
            }
          },
          "not": {
            "required": ["scope"]
          }
        }
      ]
    },
    "eventTypeList": {
      "title": "Event Type List",
      "description": "Unique references to declared event types.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/eventType"
      },
      "uniqueItems": true
    },
    "autonomyLevel": {
      "title": "Autonomy Level",
      "description": "Declared level of agent or automation independence. Autonomy does not grant permission.",
      "type": "string",
      "enum": [
        "manual_only",
        "suggest_only",
        "ask_before_changes",
        "autonomous_safe",
        "autonomous_extended"
      ]
    },
    "riskLevel": {
      "title": "Risk Level",
      "description": "Declared risk classification for a capability or operation.",
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "permissionEffect": {
      "title": "Permission Effect",
      "description": "Policy effect that allows, denies, or requires approval before capability use.",
      "type": "string",
      "enum": ["allow", "deny", "approval_required"]
    },
    "taskStatus": {
      "title": "Task Status",
      "description": "Lifecycle state of a declared task.",
      "type": "string",
      "enum": ["proposed", "ready", "in_progress", "blocked", "completed", "cancelled"]
    },
    "handoffStatus": {
      "title": "Handoff Status",
      "description": "Lifecycle state of a declared handoff.",
      "type": "string",
      "enum": ["pending", "accepted", "rejected", "blocked", "cancelled", "completed"]
    },
    "accessMode": {
      "title": "Access Mode",
      "description": "Declared mode for using a context source. Access mode does not grant permission.",
      "type": "string",
      "enum": ["none", "read", "write", "query", "admin"]
    },
    "classification": {
      "title": "Classification",
      "description": "Sensitivity classification for context or memory.",
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "networkAccessPolicy": {
      "title": "Network Access Policy",
      "description": "Fail-closed project policy for outbound network requests. This policy narrows connectivity and does not grant capabilities, permissions, credentials, context, provider access, or integration access.",
      "type": "object",
      "additionalProperties": true,
      "required": ["default", "rules", "transport", "audit"],
      "properties": {
        "default": {
          "const": "deny",
          "description": "Unmatched network requests are denied."
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "description", "effect", "actors", "purposes", "destinations"],
            "properties": {
              "id": {
                "$ref": "#/$defs/id"
              },
              "description": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "effect": {
                "$ref": "#/$defs/permissionEffect"
              },
              "actors": {
                "allOf": [
                  {
                    "$ref": "#/$defs/idList"
                  }
                ],
                "minItems": 1
              },
              "capabilities": {
                "allOf": [
                  {
                    "$ref": "#/$defs/idList"
                  }
                ],
                "minItems": 1
              },
              "purposes": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "context_read",
                    "provider_request",
                    "integration_read",
                    "integration_write",
                    "package_download",
                    "artifact_transfer",
                    "webhook_delivery",
                    "custom"
                  ]
                }
              },
              "destinations": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "domains": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 253,
                      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
                    }
                  },
                  "contextSources": {
                    "allOf": [
                      {
                        "$ref": "#/$defs/idList"
                      }
                    ],
                    "minItems": 1
                  },
                  "providers": {
                    "allOf": [
                      {
                        "$ref": "#/$defs/idList"
                      }
                    ],
                    "minItems": 1
                  },
                  "extensions": {
                    "allOf": [
                      {
                        "$ref": "#/$defs/idList"
                      }
                    ],
                    "minItems": 1
                  },
                  "schemes": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "enum": ["https", "wss", "http"]
                    }
                  },
                  "ports": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    }
                  }
                },
                "anyOf": [
                  {
                    "required": ["domains"]
                  },
                  {
                    "required": ["contextSources"]
                  },
                  {
                    "required": ["providers"]
                  },
                  {
                    "required": ["extensions"]
                  }
                ]
              },
              "maxDataClassification": {
                "$ref": "#/$defs/classification"
              },
              "approvalGate": {
                "$ref": "#/$defs/id"
              }
            },
            "allOf": [
              {
                "if": {
                  "required": ["effect"],
                  "properties": {
                    "effect": {
                      "const": "approval_required"
                    }
                  }
                },
                "then": {
                  "required": ["approvalGate"]
                },
                "else": {
                  "not": {
                    "required": ["approvalGate"]
                  }
                }
              }
            ]
          }
        },
        "transport": {
          "type": "object",
          "additionalProperties": true,
          "required": ["requireTls", "allowPrivateNetworks", "allowLoopback", "followRedirects", "maxRedirects"],
          "properties": {
            "requireTls": {
              "type": "boolean",
              "default": true
            },
            "allowPrivateNetworks": {
              "type": "boolean",
              "default": false
            },
            "allowLoopback": {
              "type": "boolean",
              "default": false
            },
            "followRedirects": {
              "type": "boolean",
              "default": false
            },
            "maxRedirects": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10,
              "default": 0
            }
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": true,
          "required": ["events", "recordDecisions", "recordDestination", "recordPurpose", "redactQuery", "redactHeaders"],
          "properties": {
            "events": {
              "allOf": [
                {
                  "$ref": "#/$defs/eventTypeList"
                }
              ],
              "minItems": 1
            },
            "recordDecisions": {
              "const": true
            },
            "recordDestination": {
              "type": "boolean"
            },
            "recordPurpose": {
              "type": "boolean"
            },
            "redactQuery": {
              "const": true
            },
            "redactHeaders": {
              "const": true
            }
          }
        }
      }
    },
    "humanOverrideOperation": {
      "title": "Human Override Operation",
      "description": "A human-control operation that can only narrow or stop effective behavior.",
      "type": "string",
      "enum": [
        "pause_agent",
        "stop_agent",
        "pause_workflow",
        "stop_workflow",
        "cancel_task",
        "block_action",
        "revoke_approval",
        "revoke_authorization"
      ]
    },
    "humanOverridePolicy": {
      "title": "Human Override Policy",
      "description": "Fail-closed project policy for human-controlled pause, stop, cancellation, blocking, and revocation. Declaration does not implement runtime enforcement.",
      "type": "object",
      "additionalProperties": false,
      "required": ["authorities", "operations", "response", "resume", "audit"],
      "properties": {
        "authorities": {
          "description": "Actors permitted to request human override. Each actor must resolve semantically to a human or fully human-represented authority.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/actorReference"
          },
          "uniqueItems": true
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/humanOverrideOperation"
          },
          "uniqueItems": true
        },
        "response": {
          "type": "object",
          "additionalProperties": false,
          "required": ["blockNewActions", "inFlightActions", "onFailure"],
          "properties": {
            "blockNewActions": {
              "description": "New target actions must remain blocked after an accepted override request.",
              "const": true
            },
            "inFlightActions": {
              "description": "Whether in-flight work receives a stop request or may reach a declared safe completion boundary.",
              "type": "string",
              "enum": ["request_stop", "allow_safe_completion"]
            },
            "onFailure": {
              "description": "Required fail-closed state when an override cannot be confirmed or applied.",
              "const": "remain_blocked"
            }
          }
        },
        "resume": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "approvalGate", "requireReason"],
          "properties": {
            "mode": {
              "const": "approval_required"
            },
            "approvalGate": {
              "$ref": "#/$defs/id"
            },
            "requireReason": {
              "const": true
            }
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "events",
            "recordAuthority",
            "recordReason",
            "recordTarget",
            "recordOutcome"
          ],
          "properties": {
            "events": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/eventType"
              },
              "uniqueItems": true
            },
            "recordAuthority": {
              "const": true
            },
            "recordReason": {
              "const": true
            },
            "recordTarget": {
              "const": true
            },
            "recordOutcome": {
              "const": true
            }
          }
        }
      }
    },
    "memoryScope": {
      "title": "Memory Scope",
      "description": "Boundary for retaining and reusing information.",
      "type": "string",
      "enum": ["ephemeral", "task", "project", "team", "user", "organization"]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "producedBy": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "approvalGate": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "description"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string"
        },
        "requiredApprovers": {
          "$ref": "#/$defs/idList"
        },
        "appliesTo": {
          "$ref": "#/$defs/idList"
        },
        "events": {
          "$ref": "#/$defs/eventTypeList"
        }
      }
    },
    "extensionAttachment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["namespace"],
      "properties": {
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
