{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexflow.dev/schemas/common.schema.json",
  "title": "NexFlow Common Definitions",
  "type": "object",
  "$defs": {
    "specVersion": {
      "title": "Spec Version",
      "description": "NexFlow spec version used to interpret the manifest.",
      "type": "string",
      "enum": ["0.1"]
    },
    "id": {
      "title": "Identifier",
      "description": "Stable, case-sensitive identifier. It starts with a lowercase letter and uses lowercase letters, digits, and non-empty segments separated by hyphens or underscores.",
      "type": "string",
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:[-_][a-z0-9]+)*$",
      "examples": ["docs-agent", "read_repository"]
    },
    "eventType": {
      "title": "Event Type",
      "description": "Dotted lowercase event type. Event types are a separate namespace from entity identifiers.",
      "type": "string",
      "pattern": "^[a-z]+(?:\\.[a-z]+)+$",
      "examples": ["task.completed", "review.requested"]
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "project": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        }
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "idList": {
      "title": "Identifier List",
      "description": "Unique identifiers or identifier references. The containing field determines the target namespace for references.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "eventTypeList": {
      "title": "Event Type List",
      "description": "Unique references to declared event types.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/eventType"
      },
      "uniqueItems": true
    },
    "autonomyLevel": {
      "title": "Autonomy Level",
      "description": "Declared level of agent or automation independence. Autonomy does not grant permission.",
      "type": "string",
      "enum": [
        "manual_only",
        "suggest_only",
        "ask_before_changes",
        "autonomous_safe",
        "autonomous_extended"
      ]
    },
    "riskLevel": {
      "title": "Risk Level",
      "description": "Declared risk classification for a capability or operation.",
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "permissionEffect": {
      "title": "Permission Effect",
      "description": "Policy effect that allows, denies, or requires approval before capability use.",
      "type": "string",
      "enum": ["allow", "deny", "approval_required"]
    },
    "taskStatus": {
      "title": "Task Status",
      "description": "Lifecycle state of a declared task.",
      "type": "string",
      "enum": ["proposed", "ready", "in_progress", "blocked", "completed", "cancelled"]
    },
    "handoffStatus": {
      "title": "Handoff Status",
      "description": "Lifecycle state of a declared handoff.",
      "type": "string",
      "enum": ["pending", "accepted", "rejected", "blocked", "cancelled", "completed"]
    },
    "accessMode": {
      "title": "Access Mode",
      "description": "Declared mode for using a context source. Access mode does not grant permission.",
      "type": "string",
      "enum": ["none", "read", "write", "query", "admin"]
    },
    "classification": {
      "title": "Classification",
      "description": "Sensitivity classification for context or memory.",
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "networkAccessPolicy": {
      "title": "Network Access Policy",
      "description": "Fail-closed project policy for outbound network requests. This policy narrows connectivity and does not grant capabilities, permissions, credentials, context, provider access, or integration access.",
      "type": "object",
      "additionalProperties": true,
      "required": ["default", "rules", "transport", "audit"],
      "properties": {
        "default": {
          "const": "deny",
          "description": "Unmatched network requests are denied."
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "description", "effect", "actors", "purposes", "destinations"],
            "properties": {
              "id": {
                "$ref": "#/$defs/id"
              },
              "description": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "effect": {
                "$ref": "#/$defs/permissionEffect"
              },
              "actors": {
                "allOf": [
                  {
                    "$ref": "#/$defs/idList"
                  }
                ],
                "minItems": 1
              },
              "capabilities": {
                "allOf": [
                  {
                    "$ref": "#/$defs/idList"
                  }
                ],
                "minItems": 1
              },
              "purposes": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "context_read",
                    "provider_request",
                    "integration_read",
                    "integration_write",
                    "package_download",
                    "artifact_transfer",
                    "webhook_delivery",
                    "custom"
                  ]
                }
              },
              "destinations": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "domains": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 253,
                      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
                    }
                  },
                  "contextSources": {
                    "allOf": [
                      {
                        "$ref": "#/$defs/idList"
                      }
                    ],
                    "minItems": 1
                  },
                  "providers": {
                    "allOf": [
                      {
                        "$ref": "#/$defs/idList"
                      }
                    ],
                    "minItems": 1
                  },
                  "extensions": {
                    "allOf": [
                      {
                        "$ref": "#/$defs/idList"
                      }
                    ],
                    "minItems": 1
                  },
                  "schemes": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "enum": ["https", "wss", "http"]
                    }
                  },
                  "ports": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    }
                  }
                },
                "anyOf": [
                  {
                    "required": ["domains"]
                  },
                  {
                    "required": ["contextSources"]
                  },
                  {
                    "required": ["providers"]
                  },
                  {
                    "required": ["extensions"]
                  }
                ]
              },
              "maxDataClassification": {
                "$ref": "#/$defs/classification"
              },
              "approvalGate": {
                "$ref": "#/$defs/id"
              }
            },
            "allOf": [
              {
                "if": {
                  "required": ["effect"],
                  "properties": {
                    "effect": {
                      "const": "approval_required"
                    }
                  }
                },
                "then": {
                  "required": ["approvalGate"]
                },
                "else": {
                  "not": {
                    "required": ["approvalGate"]
                  }
                }
              }
            ]
          }
        },
        "transport": {
          "type": "object",
          "additionalProperties": true,
          "required": ["requireTls", "allowPrivateNetworks", "allowLoopback", "followRedirects", "maxRedirects"],
          "properties": {
            "requireTls": {
              "type": "boolean",
              "default": true
            },
            "allowPrivateNetworks": {
              "type": "boolean",
              "default": false
            },
            "allowLoopback": {
              "type": "boolean",
              "default": false
            },
            "followRedirects": {
              "type": "boolean",
              "default": false
            },
            "maxRedirects": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10,
              "default": 0
            }
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": true,
          "required": ["events", "recordDecisions", "recordDestination", "recordPurpose", "redactQuery", "redactHeaders"],
          "properties": {
            "events": {
              "allOf": [
                {
                  "$ref": "#/$defs/eventTypeList"
                }
              ],
              "minItems": 1
            },
            "recordDecisions": {
              "const": true
            },
            "recordDestination": {
              "type": "boolean"
            },
            "recordPurpose": {
              "type": "boolean"
            },
            "redactQuery": {
              "const": true
            },
            "redactHeaders": {
              "const": true
            }
          }
        }
      }
    },
    "memoryScope": {
      "title": "Memory Scope",
      "description": "Boundary for retaining and reusing information.",
      "type": "string",
      "enum": ["ephemeral", "task", "project", "team", "user", "organization"]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "producedBy": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "approvalGate": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "description"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string"
        },
        "requiredApprovers": {
          "$ref": "#/$defs/idList"
        },
        "appliesTo": {
          "$ref": "#/$defs/idList"
        },
        "events": {
          "$ref": "#/$defs/eventTypeList"
        }
      }
    },
    "extensionAttachment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["namespace"],
      "properties": {
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
