{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexflow.dev/schemas/context.schema.json",
  "title": "NexFlow Context Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["specVersion", "kind", "metadata", "contextSources"],
  "properties": {
    "specVersion": {
      "$ref": "common.schema.json#/$defs/specVersion"
    },
    "kind": {
      "const": "ContextSet"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "contextSources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "type", "description", "access", "classification"],
        "properties": {
          "id": {
            "$ref": "common.schema.json#/$defs/id"
          },
          "type": {
            "type": "string",
            "enum": [
              "github",
              "gitlab",
              "docs",
              "notes",
              "confluence",
              "local_files",
              "knowledge_base",
              "linear",
              "jira",
              "figma",
              "mcp",
              "web",
              "custom"
            ]
          },
          "description": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "contentTypes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "source_code",
                "documentation",
                "issues",
                "pull_requests",
                "tickets",
                "designs",
                "knowledge_articles",
                "web_pages",
                "tool_results",
                "metadata",
                "custom"
              ]
            },
            "uniqueItems": true
          },
          "access": {
            "type": "object",
            "additionalProperties": true,
            "required": ["default"],
            "properties": {
              "default": {
                "$ref": "common.schema.json#/$defs/accessMode"
              },
              "allowedActors": {
                "$ref": "common.schema.json#/$defs/idList"
              },
              "deniedActors": {
                "$ref": "common.schema.json#/$defs/idList"
              }
            }
          },
          "classification": {
            "$ref": "common.schema.json#/$defs/classification"
          },
          "refreshPolicy": {
            "type": "string",
            "enum": ["manual", "on_request", "on_workflow_start", "scheduled", "custom"]
          },
          "freshness": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "maxAge": {
                "type": "string"
              },
              "staleAllowed": {
                "type": "boolean"
              },
              "requiresCitation": {
                "type": "boolean"
              },
              "lastReviewed": {
                "type": "string",
                "format": "date"
              }
            }
          },
          "allowedDomains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "disallowedDomains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "mcp": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "serverId": {
                "$ref": "common.schema.json#/$defs/id"
              },
              "exposes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["context", "tools", "prompts", "resources", "actions"]
                },
                "uniqueItems": true
              },
              "allowedTools": {
                "$ref": "common.schema.json#/$defs/stringList"
              },
              "requiresApprovalForTools": {
                "type": "boolean"
              }
            }
          },
          "approvalGates": {
            "$ref": "common.schema.json#/$defs/idList"
          },
          "extensions": {
            "type": "array",
            "items": {
              "$ref": "common.schema.json#/$defs/extensionAttachment"
            }
          }
        }
      }
    }
  }
}
