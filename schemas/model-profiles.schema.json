{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexflow.dev/schemas/model-profiles.schema.json",
  "title": "NexFlow Model Profiles Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["specVersion", "kind", "metadata", "modelProfiles"],
  "properties": {
    "specVersion": {
      "$ref": "common.schema.json#/$defs/specVersion"
    },
    "kind": {
      "const": "ModelProfileSet"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "modelProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "description", "modelClass", "selection", "audit"],
        "properties": {
          "id": {
            "$ref": "common.schema.json#/$defs/id"
          },
          "description": {
            "type": "string"
          },
          "modelClass": {
            "type": "string",
            "enum": [
              "reasoning",
              "coding",
              "review",
              "summarization",
              "embedding",
              "reranking",
              "multimodal",
              "custom"
            ]
          },
          "selection": {
            "type": "object",
            "additionalProperties": true,
            "required": ["mode"],
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["pinned", "floating", "policy"]
              },
              "providerRefs": {
                "$ref": "common.schema.json#/$defs/idList"
              },
              "pinnedModel": {
                "type": "object",
                "additionalProperties": true,
                "required": ["providerRef", "modelId"],
                "properties": {
                  "providerRef": {
                    "$ref": "common.schema.json#/$defs/id"
                  },
                  "modelId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "revision": {
                    "type": "string"
                  },
                  "resolvedAt": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              },
              "floatingAlias": {
                "type": "string",
                "minLength": 1
              },
              "resolutionPolicy": {
                "type": "string"
              }
            }
          },
          "constraints": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "trainingUse": {
                "type": "string",
                "enum": ["allowed", "prohibited", "requires_approval", "unspecified"]
              },
              "dataResidency": {
                "type": "string"
              },
              "toolUse": {
                "type": "string",
                "enum": ["none", "declared_tools_only", "provider_native_tools", "unspecified"]
              },
              "maxCostTier": {
                "type": "string"
              },
              "maxLatencyClass": {
                "type": "string"
              },
              "sensitivity": {
                "$ref": "common.schema.json#/$defs/classification"
              }
            }
          },
          "fallback": {
            "type": "object",
            "additionalProperties": true,
            "required": ["allowed"],
            "properties": {
              "allowed": {
                "type": "boolean"
              },
              "strategy": {
                "type": "string"
              },
              "requiresApproval": {
                "type": "boolean"
              },
              "requiresAuditEvent": {
                "type": "boolean"
              },
              "candidateProviderRefs": {
                "$ref": "common.schema.json#/$defs/idList"
              }
            }
          },
          "audit": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "recordModelProfileRef": {
                "type": "boolean"
              },
              "recordResolvedProvider": {
                "type": "boolean"
              },
              "recordResolvedModel": {
                "type": "boolean"
              },
              "recordModelRevision": {
                "type": "boolean"
              },
              "recordSelectionReason": {
                "type": "boolean"
              },
              "recordConstraintsApplied": {
                "type": "boolean"
              },
              "recordPolicyDecision": {
                "type": "boolean"
              },
              "recordFallbackUsed": {
                "type": "boolean"
              },
              "events": {
                "$ref": "common.schema.json#/$defs/idList"
              }
            }
          },
          "review": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "required": {
                "type": "boolean"
              },
              "approvers": {
                "$ref": "common.schema.json#/$defs/idList"
              },
              "reviewTriggers": {
                "$ref": "common.schema.json#/$defs/stringList"
              }
            }
          },
          "recommendedFor": {
            "$ref": "common.schema.json#/$defs/idList"
          }
        }
      }
    }
  }
}
