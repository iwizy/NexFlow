{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexflow.dev/schemas/prompt-sets.schema.json",
  "title": "NexFlow Prompt Sets Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["specVersion", "kind", "metadata", "promptSets"],
  "properties": {
    "specVersion": {
      "$ref": "common.schema.json#/$defs/specVersion"
    },
    "kind": {
      "const": "PromptSet"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "promptSets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "description", "version", "status", "owner", "prompts", "review", "audit"],
        "properties": {
          "id": {
            "$ref": "common.schema.json#/$defs/id"
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["draft", "active", "deprecated", "retired"]
          },
          "owner": {
            "$ref": "common.schema.json#/$defs/id"
          },
          "prompts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["id", "kind", "revision"],
              "properties": {
                "id": {
                  "$ref": "common.schema.json#/$defs/id"
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "system",
                    "role",
                    "workflow",
                    "task",
                    "review",
                    "safety",
                    "tool",
                    "handoff",
                    "memory",
                    "custom"
                  ]
                },
                "revision": {
                  "type": "string",
                  "minLength": 1
                },
                "sourceRef": {
                  "type": "string",
                  "minLength": 1
                },
                "contentDigest": {
                  "type": "string",
                  "minLength": 1
                },
                "inline": {
                  "type": "string"
                },
                "variables": {
                  "$ref": "common.schema.json#/$defs/stringList"
                },
                "appliesTo": {
                  "$ref": "common.schema.json#/$defs/idList"
                },
                "classification": {
                  "$ref": "common.schema.json#/$defs/classification"
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          },
          "review": {
            "type": "object",
            "additionalProperties": true,
            "required": ["required", "safetyReviewStatus"],
            "properties": {
              "required": {
                "type": "boolean"
              },
              "approvers": {
                "$ref": "common.schema.json#/$defs/idList"
              },
              "safetyReviewStatus": {
                "type": "string",
                "enum": ["not_reviewed", "pending", "approved", "changes_requested", "rejected"]
              },
              "reviewedAt": {
                "type": "string",
                "format": "date-time"
              },
              "evidenceRefs": {
                "$ref": "common.schema.json#/$defs/stringList"
              }
            }
          },
          "compatibility": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "impact": {
                "type": "string",
                "enum": [
                  "compatible",
                  "behavior_changing",
                  "safety_significant",
                  "breaking",
                  "unknown"
                ]
              },
              "notes": {
                "type": "string"
              },
              "replaces": {
                "$ref": "common.schema.json#/$defs/id"
              },
              "affectedAgents": {
                "$ref": "common.schema.json#/$defs/idList"
              },
              "affectedWorkflows": {
                "$ref": "common.schema.json#/$defs/idList"
              }
            }
          },
          "audit": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "recordPromptSetRef": {
                "type": "boolean"
              },
              "recordPromptRevisions": {
                "type": "boolean"
              },
              "recordContentDigest": {
                "type": "boolean"
              },
              "recordReviewStatus": {
                "type": "boolean"
              },
              "events": {
                "$ref": "common.schema.json#/$defs/eventTypeList"
              }
            }
          },
          "recommendedFor": {
            "$ref": "common.schema.json#/$defs/idList"
          }
        }
      }
    }
  }
}
