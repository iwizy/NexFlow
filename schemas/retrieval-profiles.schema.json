{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexflow.dev/schemas/retrieval-profiles.schema.json",
  "title": "NexFlow Retrieval Profiles Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["specVersion", "kind", "metadata", "retrievalProfiles"],
  "properties": {
    "specVersion": {
      "$ref": "common.schema.json#/$defs/specVersion"
    },
    "kind": {
      "const": "RetrievalProfileSet"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "retrievalProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "description", "version", "status", "owner", "sources", "audit"],
        "properties": {
          "id": {
            "$ref": "common.schema.json#/$defs/id"
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["draft", "active", "deprecated", "retired"]
          },
          "owner": {
            "$ref": "common.schema.json#/$defs/id"
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["contextSourceRef", "purpose"],
              "properties": {
                "contextSourceRef": {
                  "$ref": "common.schema.json#/$defs/id"
                },
                "purpose": {
                  "type": "string"
                },
                "accessMode": {
                  "$ref": "common.schema.json#/$defs/accessMode"
                },
                "required": {
                  "type": "boolean"
                },
                "maxClassification": {
                  "$ref": "common.schema.json#/$defs/classification"
                }
              }
            }
          },
          "excludedSources": {
            "$ref": "common.schema.json#/$defs/idList"
          },
          "index": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "corpusRef": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string"
              },
              "updatePolicy": {
                "type": "string",
                "enum": ["manual", "on_request", "on_workflow_start", "scheduled", "external"]
              },
              "embeddingModelProfileRef": {
                "$ref": "common.schema.json#/$defs/id"
              },
              "rerankerRef": {
                "type": "string"
              },
              "sourceDigest": {
                "type": "string"
              },
              "lastIndexedAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "chunking": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "strategy": {
                "type": "string",
                "enum": ["fixed_size", "semantic", "structure_aware", "none", "custom"]
              },
              "maxChunkTokens": {
                "type": "integer",
                "minimum": 1
              },
              "overlapTokens": {
                "type": "integer",
                "minimum": 0
              },
              "preserveBoundaries": {
                "$ref": "common.schema.json#/$defs/stringList"
              }
            }
          },
          "retriever": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "strategy": {
                "type": "string",
                "enum": ["keyword", "vector", "hybrid", "graph", "custom"]
              },
              "topK": {
                "type": "integer",
                "minimum": 1
              },
              "scoreThreshold": {
                "type": "number",
                "minimum": 0
              },
              "queryRewrite": {
                "type": "string",
                "enum": ["none", "static_policy", "model_assisted", "custom"]
              },
              "filters": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          "freshness": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "maxAge": {
                "type": "string"
              },
              "staleAllowed": {
                "type": "boolean"
              },
              "requiresRefreshBeforeUse": {
                "type": "boolean"
              },
              "citationRequiredForStale": {
                "type": "boolean"
              }
            }
          },
          "citations": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "required": {
                "type": "boolean"
              },
              "style": {
                "type": "string",
                "enum": ["source_path", "url", "artifact_id", "custom"]
              },
              "includeLineRefs": {
                "type": "boolean"
              },
              "includeRetrievedAt": {
                "type": "boolean"
              }
            }
          },
          "sensitivity": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "maxClassification": {
                "$ref": "common.schema.json#/$defs/classification"
              },
              "allowCrossScopeReuse": {
                "type": "boolean"
              },
              "redactionPolicy": {
                "type": "string"
              },
              "excludedClassifications": {
                "type": "array",
                "items": {
                  "$ref": "common.schema.json#/$defs/classification"
                },
                "uniqueItems": true
              }
            }
          },
          "review": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "required": {
                "type": "boolean"
              },
              "approvers": {
                "$ref": "common.schema.json#/$defs/idList"
              },
              "reviewTriggers": {
                "$ref": "common.schema.json#/$defs/stringList"
              }
            }
          },
          "compatibility": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "impact": {
                "type": "string",
                "enum": [
                  "compatible",
                  "behavior_changing",
                  "safety_significant",
                  "breaking",
                  "unknown"
                ]
              },
              "notes": {
                "type": "string"
              },
              "replaces": {
                "$ref": "common.schema.json#/$defs/id"
              },
              "affectedAgents": {
                "$ref": "common.schema.json#/$defs/idList"
              },
              "affectedWorkflows": {
                "$ref": "common.schema.json#/$defs/idList"
              }
            }
          },
          "audit": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "recordRetrievalProfileRef": {
                "type": "boolean"
              },
              "recordContextSources": {
                "type": "boolean"
              },
              "recordIndexVersion": {
                "type": "boolean"
              },
              "recordFreshness": {
                "type": "boolean"
              },
              "recordCitations": {
                "type": "boolean"
              },
              "recordRetrieverConfig": {
                "type": "boolean"
              },
              "events": {
                "$ref": "common.schema.json#/$defs/eventTypeList"
              }
            }
          },
          "recommendedFor": {
            "$ref": "common.schema.json#/$defs/idList"
          }
        }
      }
    }
  }
}
