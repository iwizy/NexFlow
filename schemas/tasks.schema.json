{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexflow.dev/schemas/tasks.schema.json",
  "title": "NexFlow Tasks Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["specVersion", "kind", "metadata", "tasks"],
  "properties": {
    "specVersion": {
      "$ref": "common.schema.json#/$defs/specVersion"
    },
    "kind": {
      "const": "TaskSet"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title", "status", "owner", "acceptanceCriteria"],
        "properties": {
          "id": {
            "$ref": "common.schema.json#/$defs/id"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "$ref": "common.schema.json#/$defs/taskStatus"
          },
          "owner": {
            "$ref": "common.schema.json#/$defs/id"
          },
          "participants": {
            "$ref": "common.schema.json#/$defs/idList"
          },
          "dependsOn": {
            "$ref": "common.schema.json#/$defs/idList"
          },
          "artifacts": {
            "type": "array",
            "items": {
              "$ref": "common.schema.json#/$defs/artifact"
            }
          },
          "capabilitiesRequired": {
            "$ref": "common.schema.json#/$defs/idList"
          },
          "approvalGates": {
            "$ref": "common.schema.json#/$defs/idList"
          },
          "acceptanceCriteria": {
            "$ref": "common.schema.json#/$defs/stringList"
          }
        }
      }
    }
  }
}
