{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexflow.dev/schemas/workflow.schema.json",
  "title": "NexFlow Workflow Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["specVersion", "kind", "metadata", "workflow"],
  "properties": {
    "specVersion": {
      "$ref": "common.schema.json#/$defs/specVersion"
    },
    "kind": {
      "const": "Workflow"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "workflow": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "displayName", "stages"],
      "properties": {
        "id": {
          "$ref": "common.schema.json#/$defs/id"
        },
        "displayName": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "displayName", "steps"],
            "properties": {
              "id": {
                "$ref": "common.schema.json#/$defs/id"
              },
              "displayName": {
                "type": "string"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["id", "task"],
                  "properties": {
                    "id": {
                      "$ref": "common.schema.json#/$defs/id"
                    },
                    "task": {
                      "$ref": "common.schema.json#/$defs/id"
                    },
                    "dependsOn": {
                      "$ref": "common.schema.json#/$defs/idList"
                    },
                    "approvalGates": {
                      "$ref": "common.schema.json#/$defs/idList"
                    },
                    "emits": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "uniqueItems": true
                    }
                  }
                }
              }
            }
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["from", "to"],
            "properties": {
              "from": {
                "$ref": "common.schema.json#/$defs/id"
              },
              "to": {
                "$ref": "common.schema.json#/$defs/id"
              },
              "type": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
